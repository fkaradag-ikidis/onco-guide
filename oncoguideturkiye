        function showStep(n) {
            // Tüm adımları gizle
            document.querySelectorAll('.step-content').forEach(el => {
                el.classList.add('hidden');
                el.classList.remove('fade-in');
            });
            
            // İstenen adımı göster
            const targetStep = document.getElementById('step' + n);
            if (targetStep) {
                targetStep.classList.remove('hidden');
                targetStep.classList.add('fade-in');
            }
            
            // Progress bar güncelle
            const progressBar = document.getElementById('progressBar');
            if (progressBar) {
                progressBar.style.width = (n / 6 * 100) + '%';
            }
            
            // Sayfayı yukarı kaydır
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function selectStage(stage) {
            state.stage = stage;
            state.cancer = null; // Reset cancer selection
            populateCancers();
            showStep(2);
        }

        function populateCancers() {
            const container = document.getElementById('cancerOptions');
            if (!container) return;
            
            container.innerHTML = '';
            
            // Kategorilere göre grupla
            const categories = {};
            Object.entries(cancers).forEach(([key, val]) => {
                if (!categories[val.category]) categories[val.category] = [];
                categories[val.category].push([key, val]);
            });
            
            // Kategorileri sıralı göster
            const categoryOrder = ["Meme", "Jinekolojik", "Gastrointestinal", "Akciğer", "Ürogenital", "Deri", "Baş-Boyun", "Sinir Sistemi", "Sarkom", "Hematolojik", "Nöroendokrin", "Nadir"];
            
            categoryOrder.forEach(cat => {
                if (categories[cat]) {
                    const catTitle = document.createElement('div');
                    catTitle.className = 'category-title';
                    catTitle.textContent = cat;
                    container.appendChild(catTitle);
                    
                    categories[cat].forEach(([key, val]) => {
                        const div = document.createElement('div');
                        div.className = 'option';
                        div.onclick = () => selectCancer(key);
                        
                        // Güvenli erişim için kontroller
                        const germlineTag = val.germline && val.germline.length > 0 
                            ? `<span class="tag">Kalıtsal: ${val.germline[0]}</span>` 
                            : '';
                        const somaticTag = val.somatic && val.somatic.length > 0 
                            ? `<span class="tag">Somatik: ${val.somatic[0]}</span>` 
                            : '';
                        
                        div.innerHTML = `
                            <span class="option-icon">${val.icon || '🔹'}</span>
                            <div class="option-title">${val.name}</div>
                            <div class="option-tags">
                                ${germlineTag}
                                ${somaticTag}
                            </div>
                        `;
                        container.appendChild(div);
                    });
                }
            });
        }

        function filterCancers() {
            const searchInput = document.getElementById('cancerSearch');
            if (!searchInput) return;
            
            const search = searchInput.value.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
            const options = document.querySelectorAll('#cancerOptions .option');
            const titles = document.querySelectorAll('#cancerOptions .category-title');
            
            options.forEach(opt => {
                const text = opt.textContent.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
                opt.style.display = text.includes(search) ? 'block' : 'none';
            });
            
            // Boş kategorileri gizle
            titles.forEach(title => {
                let next = title.nextElementSibling;
                let hasVisible = false;
                while (next && !next.classList.contains('category-title')) {
                    if (next.classList.contains('option') && next.style.display !== 'none') {
                        hasVisible = true;
                    }
                    next = next.nextElementSibling;
                }
                title.style.display = hasVisible ? 'block' : 'none';
            });
        }

