        function populateLabs() {
            const container = document.getElementById('labOptions');
            const continueBtn = document.getElementById('continueBtn');
            if (!container) return;
            
            container.innerHTML = '';
            selectedLabId = null;
            state.lab = null;
            if (continueBtn) continueBtn.disabled = true;
            
            // Test tipine göre uygun laboratuvarları filtrele
            let suitableLabs = labs;
            if (state.test === 'liquid') {
                suitableLabs = labs.filter(l => l.tests.some(t => t.includes('Likit') || t.includes('Sıvı') || t.includes('Streptek')));
            } else if (state.test === 'germline' || state.test === 'brca' || state.test === 'lynch') {
                suitableLabs = labs.filter(l => l.tests.some(t => t.includes('BRCA') || t.includes('WES') || t.includes('360')));
            }
            
            suitableLabs.forEach(lab => {
                const div = document.createElement('div');
                div.className = 'lab-option';
                div.onclick = () => selectLab(lab.id, div);
                div.innerHTML = `
                    <div class="lab-name">${lab.name}</div>
                    <div class="lab-loc">📍 ${lab.loc}</div>
                    <div class="lab-tests">
                        ${lab.tests.slice(0, 3).map(t => `<span class="lab-test-tag">${t}</span>`).join('')}
                    </div>
                    <div class="lab-features">
                        ${lab.features.map(f => `<span>⭐ ${f}</span>`).join('')}
                    </div>
                `;
                container.appendChild(div);
            });
        }

        function selectLab(labId, element) {
            // Önceki seçimi kaldır
            document.querySelectorAll('.lab-option').forEach(el => el.classList.remove('selected'));
            
            // Yeni seçimi işaretle
            element.classList.add('selected');
            selectedLabId = labId;
            state.lab = labs.find(l => l.id === labId);
            
            // Devam butonunu aktifleştir
            const continueBtn = document.getElementById('continueBtn');
            if (continueBtn) continueBtn.disabled = false;
        }

