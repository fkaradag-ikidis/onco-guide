                            <li><strong>TMB-Yüksek (>10 mut/Mb):</strong> Pembrolizumab (tümör türü bağımsız)</li>
                            <li><strong>İnflamatuar Gen İfadesi:</strong> İmmünoterapi yanıt prediksiyonu</li>
                        </ul>
                    </div>
                `;
            }
            
            container.innerHTML = html;
        }

        function goBack(n) {
            showStep(n);
        }

        function resetApp() {
            state = { stage: null, cancer: null, test: null, lab: null };
            selectedLabId = null;
            const searchInput = document.getElementById('cancerSearch');
            if (searchInput) searchInput.value = '';
            showStep(1);
        }

        // Başlangıç
        showStep(1);
    </script>
</body>
