                    <div class="option-tags"><span class="tag">Tedavi</span><span class="tag">Hedefe Yönelik</span></div>
                </div>
            </div>
        </div>
        <div id="step2" class="step-content hidden">
            <div class="card">
                <div class="step-header">
                    <div class="step-number">2</div>
                    <div>
                        <div class="step-title">Kanser Türü</div>
                        <div class="step-subtitle">Hangi kanser için test yapılacak?</div>
                    </div>
                </div>
                <input type="text" class="search-box" id="cancerSearch" placeholder="Kanser türü ara..." onkeyup="filterCancers()">
                <div id="cancerOptions"></div>
                <button class="btn btn-back" onclick="goBack(1)">← Geri Dön</button>
            </div>
        </div>
        <div id="step3" class="step-content hidden">
            <div class="card">
                <div class="step-header">
                    <div class="step-number">3</div>
                    <div>
                        <div class="step-title">Test Türü</div>
                        <div class="step-subtitle" id="testSubtitle">Test amacını seçin</div>
                    </div>
                </div>
                <div id="testOptions"></div>
                <button class="btn btn-back" onclick="goBack(2)">← Geri Dön</button>
            </div>
        </div>
        <div id="step4" class="step-content hidden">
            <div class="card">
                <div class="step-header">
                    <div class="step-number">4</div>
                    <div>
                        <div class="step-title">Laboratuvar Seçimi</div>
                        <div class="step-subtitle">Testi hangi merkeze göndereceksiniz?</div>
                    </div>
                </div>
                <div id="labOptions"></div>
                <button class="btn" id="continueBtn" onclick="goToSample()" disabled>Devam Et →</button>
                <button class="btn btn-back" onclick="goBack(3)">← Geri Dön</button>
            </div>
        </div>
        <div id="step5" class="step-content hidden">
            <div class="card">
                <div class="step-header">
                    <div class="step-number">5</div>
                    <div>
                        <div class="step-title">Numune Hazırlama</div>
                        <div class="step-subtitle">Seçilen laboratuvar için talimatlar</div>
                    </div>
                </div>
                <div id="selectedLabDisplay"></div>
                <div id="sampleInstructions"></div>
                <div class="alert" id="sampleAlert"></div>
                <button class="btn" onclick="goToResults()">Sonuçları Gör →</button>
                <button class="btn btn-back" onclick="goBack(4)">← Geri Dön</button>
            </div>
        </div>
        <div id="step6" class="step-content hidden">
            <div class="card">
                <div class="step-header">
                    <div class="step-number">6</div>
                    <div>
                        <div class="step-title">Sonuç ve Tedavi</div>
                        <div class="step-subtitle">Olası bulgular ve yaklaşımlar</div>
                    </div>
                </div>
                <div id="treatmentResults"></div>
                <div class="warning-box">
